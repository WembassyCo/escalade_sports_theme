{#
/**
 * @file
 * Theme override to display a Discussion Topic node.
 *
 * Custom template for Discussion Topic/Forum content type with Bootstrap 5 styling.
 * Includes topic metadata, author info, and reply/thread formatting.
 */
#}
{%
  set classes = [
    'node',
    'node--type-discussion-topic',
    'card',
    'mb-4',
    'shadow-sm',
    node.isPromoted() ? 'node--promoted border-primary',
    node.isSticky() ? 'node--sticky border-warning',
    not node.isPublished() ? 'node--unpublished bg-light',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  
  {# Card header with topic title #}
  <header class="card-header bg-light d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      {# Topic icon #}
      <div class="discussion-icon flex-shrink-0">
        <span class="badge bg-primary rounded-circle p-2">
          <i class="bi bi-chat-square-text fs-5"></i>
        </span>
      </div>
      
      {# Title #}
      {% if label and not page %}
        <h3 class="h5 mb-0">
          <a href="{{ url }}" rel="bookmark" class="text-decoration-none text-dark">
            {{ label }}
          </a>
        </h3>
      {% else %}
        <h1{{ title_attributes.addClass('h4 mb-0 text-primary') }}>{{ label }}</h1>
      {% endif %}
    </div>
    
    {# Topic status badges #}
    <div class="d-flex gap-2">
      {% if not node.isPublished() %}
        <span class="badge bg-secondary">Unpublished</span>
      {% endif %}
      {% if node.isSticky() %}
        <span class="badge bg-warning text-dark">
          <i class="bi bi-pin-fill me-1"></i>Pinned
        </span>
      {% endif %}
      {% if content.comment_forum|length > 0 %}
        <span class="badge bg-info">
          <i class="bi bi-chat-dots me-1"></i>
          {{ content.comment_forum['#items']|length }}
        </span>
      {% endif %}
    </div>
  </header>
  
  {{ title_suffix }}

  {# Topic meta and author info #}
  {% if display_submitted %}
    <div class="card-header border-top py-2 bg-white">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          {% if author_picture %}
            <div class="flex-shrink-0">
              {{ author_picture }}
            </div>
          {% endif %}
          <div>
            <span class="fw-semibold text-dark">{{ author_name }}</span>
            <div class="text-muted small">
              <i class="bi bi-clock me-1"></i>{{ date }}
            </div>
          </div>
        </div>
        
        {# Topic categories/tags #}
        {% if content.field_forum_category|length > 0 %}
          <div class="d-none d-md-block">
            {{ content.field_forum_category }}
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {# Main content body #}
  <div{{ content_attributes.addClass('card-body') }}>
    <div class="discussion-content">
      {{ content.body }}
      
      {# Attachments if any #}
      {% if content.field_attachments|length > 0 %}
        <div class="discussion-attachments mt-4 p-3 bg-light rounded">
          <h4 class="h6 text-muted mb-3">
            <i class="bi bi-paperclip me-1"></i>Attachments
          </h4>
          <div class="d-flex flex-wrap gap-2">
            {{ content.field_attachments }}
          </div>
        </div>
      {% endif %}
    </div>
    
    {# Topic actions - edit/delete etc #}
    {% if content.links %}
      <div class="discussion-actions mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
        <div class="d-flex gap-2">
          {{ content.links }}
        </div>
        
        {# Reply button for full page #}
        {% if page and logged_in %}
          <a href="#reply-form" class="btn btn-primary btn-sm">
            <i class="bi bi-reply-fill me-1"></i>Reply
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {# Footer with topic stats #}
  <div class="card-footer bg-light py-2 d-flex justify-content-between align-items-center small">
    <div class="d-flex align-items-center gap-3 text-muted">
      <span>
        <i class="bi bi-eye me-1"></i>{{ node.getRevisionId() ? 'Updated' : 'New' }}
      </span>
      {% if node.isPromoted() %}
        <span class="badge bg-success">
          <i class="bi bi-star-fill me-1"></i>Featured
        </span>
      {% endif %}
    </div>
    
    {# Share/copy link #}
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="navigator.clipboard.writeText('{{ url| absolute_url }}')" title="Copy link">
        <i class="bi bi-link-45deg"></i>
      </button>
    </div>
  </div>

  {# Comments/Forum replies section #}
  {% if content.comment_forum|length > 0 and page %}
    <div class="card-footer p-0 border-top-0">
      <div class="discussion-comments bg-light">
        {{ content.comment_forum }}
      </div>
    </div>
  {% endif %}

</article>
