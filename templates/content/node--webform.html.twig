{#
/**
 * @file
 * Theme override to display a Webform node.
 *
 * Custom template for Webform content type with Bootstrap 5 styling.
 * This template wraps the embedded webform with proper Bootstrap form styling.
 *
 * The webform entity reference field renders the actual form.
 * Form components are styled via Bootstrap form classes in the library configuration.
 */
#}
{%
  set classes = [
    'node',
    'node--type-webform',
    'container',
    'py-4',
    'clearfix',
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished bg-light',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  
  {# Title section #}
  {% if label and not page %}
    <header class="mb-3">
      <h2{{ title_attributes.addClass('display-6 fw-bold text-dark') }}>
        <a href="{{ url }}" rel="bookmark" class="text-decoration-none hover-primary">{{ label }}</a>
      </h2>
    </header>
  {% else %}
    <header class="mb-4 border-bottom pb-3">
      <h1{{ title_attributes.addClass('display-5 fw-bold text-primary') }}>{{ label }}</h1>
    </header>
  {% endif %}
  
  {{ title_suffix }}

  {# Meta information #}
  {% if display_submitted %}
    <div class="webform-meta d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded">
      {% if author_picture %}
        <div class="flex-shrink-0">
          {{ author_picture }}
        </div>
      {% endif %}
      <div class="d-flex flex-column">
        <span class="fw-semibold text-dark">{{ author_name }}</span>
        <span class="text-muted small">
          <i class="bi bi-calendar-event me-1"></i>{{ date }}
        </span>
      </div>
    </div>
  {% endif %}

  {# Webform description/body content #}
  {% if content.body|length > 0 %}
    <div class="webform-description mb-4">
      <div class="lead text-muted">
        {{ content.body }}
      </div>
    </div>
  {% endif %}

  {# Webform container with Bootstrap card styling #}
  <div class="card shadow-sm">
    <div class="card-body p-4 p-lg-5">
      {# Webform entity reference renders here #}
      <div class="webform-embed">
        {{ content|without('body', 'links') }}
      </div>
    </div>
  </div>

  {# Links #}
  {% if content.links %}
    <nav class="mt-4 pt-3 border-top" aria-label="Webform links">
      {{ content.links }}
    </nav>
  {% endif %}

</article>
