{#
/**
 * @file
 * Theme override to display a Page node.
 *
 * Custom template for Page content type - full view mode.
 */
#}
{%
  set classes = [
    'node',
    'node--type-page',
    'container',
    'py-4',
    'clearfix',
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished bg-light',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  
  {# Show title on non-full page views only #}
  {% if label and not page %}
    <header class="mb-4 border-bottom pb-3">
      <h2{{ title_attributes.addClass('h3 text-primary') }}>
        <a href="{{ url }}" rel="bookmark" class="text-decoration-none">{{ label }}</a>
      </h2>
    </header>
  {% endif %}
  
  {{ title_suffix }}

  {# Display submitted info (author, date) #}
  {% if display_submitted %}
    <footer class="d-flex align-items-center gap-3 mb-4 text-muted small">
      {% if author_picture %}
        <div class="flex-shrink-0">
          {{ author_picture }}
        </div>
      {% endif %}
      <div class="d-flex flex-column">
        <span>
          {% trans %}By {{ author_name }} on {{ date }}{% endtrans %}
        </span>
      </div>
    </footer>
  {% endif %}

  {# Main content area #}
  <div{{ content_attributes.addClass('node__content card border-0') }}>
    <div class="card-body">
      {# Page content with responsive typography #}
      <div class="content-body">
        {{ content|without('links') }}
      </div>
    </div>
  </div>

  {# Links section (edit, delete, etc.) #}
  {% if content.links %}
    <nav class="mt-4 pt-3 border-top" aria-label="Node links">
      <div class="d-flex gap-2">
        {{ content.links }}
      </div>
    </nav>
  {% endif %}

</article>
