{#
/**
 * @file
 * Theme override to display a News Item node.
 *
 * Custom template for News Item content type with Bootstrap 5 styling.
 * Supports YouTube videos, SharePoint videos, image galleries (6-column grid),
 * and single image displays.
 */
#}
{%
  set classes = [
    'node',
    'node--type-news-item',
    'container',
    'py-4',
    'clearfix',
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished bg-light',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  
  {# Title section #}
  {% if label and not page %}
    <header class="mb-3">
      <h2{{ title_attributes.addClass('display-6 fw-bold text-dark') }}>
        <a href="{{ url }}" rel="bookmark" class="text-decoration-none hover-primary">{{ label }}</a>
      </h2>
    </header>
  {% else %}
    <header class="mb-4 border-bottom pb-3">
      <h1{{ title_attributes.addClass('display-5 fw-bold text-primary') }}>{{ label }}</h1>
    </header>
  {% endif %}
  
  {{ title_suffix }}

  {# News meta information #}
  {% if display_submitted %}
    <div class="news-meta d-flex flex-wrap align-items-center gap-3 mb-4 p-3 bg-light rounded">
      {% if author_picture %}
        <div class="flex-shrink-0">
          {{ author_picture }}
        </div>
      {% endif %}
      <div class="d-flex flex-column">
        <span class="fw-semibold text-dark">{{ author_name }}</span>
        <span class="text-muted small">
          <i class="bi bi-calendar-event me-1"></i>{{ date }}
        </span>
      </div>
    </div>
  {% endif %}

  {# Video Support - YouTube/SharePoint #}
  {% if content.field_video_url|length > 0 or content.field_video|length > 0 %}
    <div class="news-video mb-4">
      {% if content.field_video_url|length > 0 %}
        {% set video_url = content.field_video_url|render|striptags|trim %}
        {% if 'youtube.com' in video_url or 'youtu.be' in video_url %}
          {# Parse YouTube URL to get video ID #}
          {% set youtube_id = video_url|replace({'https://www.youtube.com/watch?v=': '', 'https://youtube.com/watch?v=': '', 'https://youtu.be/': '', 'http://www.youtube.com/watch?v=': '', 'http://youtube.com/watch?v=': '', 'http://youtu.be/': ''}) %}
          <div class="ratio ratio-16x9">
            <iframe 
              src="https://www.youtube.com/embed/{{ youtube_id|split('&')|first }}" 
              title="YouTube video player" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen>
            </iframe>
          </div>
        {% elseif 'sharepoint.com' in video_url %}
          <div class="ratio ratio-16x9">
            <iframe 
              src="{{ video_url }}" 
              title="SharePoint video player" 
              frameborder="0" 
              allowfullscreen>
            </iframe>
          </div>
        {% else %}
          <div class="alert alert-info">
            <a href="{{ video_url }}" target="_blank" rel="noopener" class="alert-link">
              <i class="bi bi-play-circle me-2"></i>Watch Video
            </a>
          </div>
        {% endif %}
      {% elseif content.field_video|length > 0 %}
        <div class="ratio ratio-16x9">
          {{ content.field_video }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# Image Gallery - 6 Column Grid Layout #}
  {% if content.field_images|length > 0 %}
    {% set images = content.field_images|field_values %}
    {% if images|length > 1 %}
      <div class="news-image-gallery mb-4">
        <h4 class="mb-3 text-secondary">Photo Gallery</h4>
        <div class="row g-2">
          {% for image in images %}
            <div class="col-2">
              <a href="{{ image.url }}" class="d-block" data-bs-toggle="lightbox" data-gallery="news-gallery">
                <img src="{{ image.url }}" alt="{{ image.alt }}" class="img-fluid rounded" style="width: 175px; height: 175px; object-fit: cover;">
              </a>
            </div>
            {% if loop.index is divisible by(6) and not loop.last %}
              <div class="w-100"></div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      {# Single Image - Medium thumbnail style #}
      <div class="news-single-image mb-4 text-center">
        {% for image in images %}
          <figure class="figure">
            <img src="{{ image.url }}" alt="{{ image.alt }}" class="img-fluid rounded" style="max-width: 300px;">
            {% if image.alt %}
              <figcaption class="figure-caption text-center mt-2">{{ image.alt }}</figcaption>
            {% endif %}
          </figure>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}

  {# Main content area #}
  <div{{ content_attributes.addClass('node__content news-content') }}>
    {{ content.body }}
  </div>

  {# Links #}
  {% if content.links %}
    <nav class="mt-4 pt-3 border-top" aria-label="News links">
      {{ content.links }}
    </nav>
  {% endif %}

</article>
