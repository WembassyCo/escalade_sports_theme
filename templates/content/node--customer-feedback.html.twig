{#
/**
 * @file
 * Theme override to display a Customer Feedback (Team Shoutout) node.
 *
 * Custom template for Customer Feedback content type with Bootstrap 5 styling.
 * Used for recognizing and featuring team members.
 */
#}
{%
  set classes = [
    'node',
    'node--type-customer-feedback',
    'container',
    'py-4',
    'clearfix',
    'team-shoutout',
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished bg-light',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  
  {# Header with badge #}
  <div class="shoutout-header d-flex align-items-center gap-3 mb-4">
    <div class="shoutout-icon">
      <span class="display-1">🎉</span>
    </div>
    <div class="shoutout-title-wrapper">
      {% if label and not page %}
        <header>
          <h2{{ title_attributes.addClass('display-6 fw-bold text-dark') }}>
            <a href="{{ url }}" rel="bookmark" class="text-decoration-none hover-primary">{{ label }}</a>
          </h2>
        </header>
      {% else %}
        <header>
          <h1{{ title_attributes.addClass('display-5 fw-bold text-primary') }}>{{ label }}</h1>
        </header>
      {% endif %}
      <div class="badge bg-success fs-6">
        <i class="bi bi-trophy me-1"></i>{{ 'Team Shoutout'|t }}
      </div>
    </div>
  </div>
  
  {{ title_suffix }}

  {# Shoutout content #}
  <div class="shoutout-content mb-4 p-4 bg-light rounded border border-success border-opacity-25">
    
    {# Recipient information #}
    {% if content.field_recipient|length > 0 %}
      <div class="recipient d-flex align-items-center gap-3 mb-3 pb-3 border-bottom border-success border-opacity-25">
        {% if content.field_recipient_picture|length > 0 %}
          <div class="recipient-picture">
            {{ content.field_recipient_picture }}
          </div>
        {% endif %}
        <div class="recipient-info">
          <span class="text-muted">{{ 'Recognizing'|t }}:</span>
          <h3 class="h5 fw-bold text-success mb-0">{{ content.field_recipient }}</h3>
          {% if content.field_recipient_department|length > 0 %}
            <small class="text-muted">{{ content.field_recipient_department }}</small>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {# From/Author #}
    {% if display_submitted or content.field_from|length > 0 %}
      <div class="from-info d-flex align-items-center gap-2 mb-3 text-muted small">
        <i class="bi bi-person-heart"></i>
        <span>{{ 'From:'|t }} {{ author_name }}</span>
        {% if date %}
          <span class="ms-2"><i class="bi bi-calendar-event"></i> {{ date }}</span>
        {% endif %}
      </div>
    {% endif %}

    {# Main content - the shoutout message #}
    <div{{ content_attributes.addClass('node__content shoutout-message fst-italic fs-5 text-dark') }}>
      {{ content.body }}
    </div>

    {# Additional fields #}
    {% if content.field_category|length > 0 %}
      <div class="shoutout-category mt-3 pt-3 border-top border-success border-opacity-25">
        <span class="text-muted small">{{ 'Category'|t }}:</span>
        {{ content.field_category }}
      </div>
    {% endif %}

  </div>

  {# Links #}
  {% if content.links %}
    <nav class="mt-4 pt-3 border-top" aria-label="Shoutout links">
      {{ content.links }}
    </nav>
  {% endif %}

</article>
