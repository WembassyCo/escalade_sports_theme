{#
/**
 * @file
 * Theme override to display a view of unformatted rows for News Lists (Block).
 *
 * WP 2294: View templates for news-lists
 */
#}
{% if title %}
  <h4 class="view-title" style="font-size: 1.25em;">{{ title }}</h4>
{% endif %}

<div class="view-news-lists view-display-id-block">
  {% for key, row in rows %}
    {% set row_classes = [
      default_row_class ? 'views-row',
      'd-block',
      'clearfix',
      'mb-3',
      'pb-3',
      loop.last ? '' : 'border-bottom',
    ] %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{- row.content -}}
    </div>
  {% endfor %}
</div>

{% if more %}
  <div class="view-more mt-3">{{ more }}</div>
{% endif %}

{% if footer %}
  <footer class="view-footer mt-3 pt-2 border-top">{{ footer }}</footer>
{% endif %}
