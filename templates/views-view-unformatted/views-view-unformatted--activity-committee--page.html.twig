{#
/**
 * @file
 * Theme override to display a view of unformatted rows for Activity Committee.
 *
 * WP 2286: View templates for activity-committee
 *
 * Styling from D7:
 * - Page title at 1.5em
 * - Float-based row layout
 * - Similar structure to discussion topics
 */
#}
{% if title %}
  <h3 class="view-title" style="font-size: 1.5em;">{{ title }}</h3>
{% endif %}

<div class="view-activity-committee view-display-id-page">
  {% for key, row in rows %}
    {% set row_classes = [
      default_row_class ? 'views-row',
      'd-block',
      'w-100',
      'clearfix',
      'float-left',
      'mb-3',
    ] %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{- row.content -}}
    </div>
  {% endfor %}
</div>

{% if pager %}
  <div class="view-pager mt-4">{{ pager }}</div>
{% endif %}

{% if more %}
  <div class="view-more mt-3">{{ more }}</div>
{% endif %}

{% if footer %}
  <footer class="view-footer mt-4 pt-3 border-top">{{ footer }}</footer>
{% endif %}
