{#
/**
 * @file
 * Theme override to display a view of unformatted rows for News Lists (Page - Archive).
 *
 * WP 2294: View templates for news-lists (archive page)
 */
#}
{% if title %}
  <h3 class="view-title" style="font-size: 1.5em;">{{ title }}</h3>
{% endif %}

<div class="view-news-lists view-display-id-page news-archive">
  {% for key, row in rows %}
    {% set row_classes = [
      default_row_class ? 'views-row',
      'd-block',
      'clearfix',
      'mb-4',
      'pb-4',
      loop.last ? '' : 'border-bottom',
    ] %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{- row.content -}}
    </div>
  {% endfor %}
</div>

{% if pager %}
  <div class="view-pager mt-4">{{ pager }}</div>
{% endif %}

{% if more %}
  <div class="view-more mt-3">{{ more }}</div>
{% endif %}

{% if footer %}
  <footer class="view-footer mt-4 pt-3 border-top">{{ footer }}</footer>
{% endif %}
