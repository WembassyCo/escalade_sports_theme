{#
/**
 * @file
 * Theme override to display a view of unformatted rows for New Employees Block.
 *
 * WP 2284: View templates for new-employees (block view)
 *
 * Styling from D7:
 * - Block view: 100px image width
 * - Image floated left
 * - Name: color #000, font-size 1.1em
 * - Border-bottom separator
 */
#}
{% if title %}
  <h4 class="view-title" style="font-size: 1.25em;">{{ title }}</h4>
{% endif %}

<div class="view-new-employees view-display-id-block new-employees">
  {% for key, row in rows %}
    {% set row_classes = [
      default_row_class ? 'views-row',
      'new-employ',
      'd-block',
      'w-100',
      'clearfix',
      'mb-3',
      loop.last ? '' : 'pb-2 border-bottom',
    ] %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{- row.content -}}
    </div>
  {% endfor %}
</div>

{% if more %}
  <div class="view-more mt-3">{{ more }}</div>
{% endif %}

{% if footer %}
  <footer class="view-footer mt-3 pt-2 border-top">{{ footer }}</footer>
{% endif %}
