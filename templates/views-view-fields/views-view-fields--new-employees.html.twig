{#
/**
 * @file
 * Theme override for view fields in New Employees view.
 *
 * Available variables:
 * - view: The view object.
 * - fields: A list of fields, each one contains:
 *   - content: The output of the field.
 *   - raw: The raw data for the field.
 *   - class: The safe class ID to use.
 *   - handler: The Views field handler object.
 *   - inline: Whether or not the field should be inline.
 *   - label: The label text.
 * @ingroup templates
 */
#}

{# New Employee Card #}
<div class="new-employee-card card h-100 shadow-sm border-0 text-center">
  <div class="card-body p-4">
    
    {# Employee Photo #}
    {% if fields.field_employee_photo and fields.field_employee_photo.content|striptags|trim is not empty %}
      <div class="employee-photo mb-3">
        <img src="{{ fields.field_employee_photo.content|striptags|trim }}" 
             alt="{{ fields.title.content|striptags|trim }}" 
             class="rounded-circle mx-auto d-block"
             style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #0A4C97;">
      </div>
    {% else %}
      {# Default avatar placeholder #}
      <div class="employee-photo-placeholder mb-3 mx-auto rounded-circle d-flex align-items-center justify-content-center"
           style="width: 120px; height: 120px; background: linear-gradient(135deg, #0A4C97 0%, #00ADEE 100%);">
        <i class="bi bi-person-fill text-white fs-1"></i>
      </div>
    {% endif %}
    
    {# Employee Name #}
    {% if fields.title %}
      <h3 class="card-title h5 mb-1">
        <a href="{{ fields.view_node.content|default(fields.path.content)|default('#') }}" 
           class="text-decoration-none text-dark fw-bold hover-primary">
          {{ fields.title.content }}
        </a>
      </h3>
    {% endif %}
    
    {# Job Title #}
    {% if fields.field_job_title and fields.field_job_title.content|striptags|trim is not empty %}
      <p class="text-primary fw-semibold mb-2">
        {{ fields.field_job_title.content }}
      </p>
    {% endif %}
    
    {# Business Unit #}
    {% if fields.field_business_unit and fields.field_business_unit.content|striptags|trim is not empty %}
      <p class="text-muted small mb-2">
        <i class="bi bi-building me-1"></i>{{ fields.field_business_unit.content }}
      </p>
    {% endif %}
    
    {# Start Date Badge #}
    {% if fields.field_start_date or fields.created %}
      <div class="mt-3">
        <span class="badge bg-light text-dark border">
          <i class="bi bi-calendar-check text-success me-1"></i>
          Started: {{ fields.field_start_date.content|default(fields.created.content) }}
        </span>
      </div>
    {% endif %}
    
    {# Contact Links #}
    <div class="mt-3 d-flex justify-content-center gap-2">
      {% if fields.field_email and fields.field_email.content|striptags|trim is not empty %}
        <a href="mailto:{{ fields.field_email.content|striptags|trim }}" 
           class="btn btn-sm btn-outline-primary"
           title="Send Email">
          <i class="bi bi-envelope"></i>
        </a>
      {% endif %}
      {% if fields.field_phone and fields.field_phone.content|striptags|trim is not empty %}
        <a href="tel:{{ fields.field_phone.content|striptags|trim }}" 
           class="btn btn-sm btn-outline-primary"
           title="Call">
          <i class="bi bi-telephone"></i>
        </a>
      {% endif %}
    </div>
    
  </div>
  
  {# Card Footer with Profile Link #}
  <div class="card-footer bg-light border-0 p-3">
    <a href="{{ fields.view_node.content|default(fields.path.content)|default('#') }}" 
       class="btn btn-primary btn-sm w-100">
      View Profile <i class="bi bi-arrow-right ms-1"></i>
    </a>
  </div>
</div>
